# Copy to .env and fill in. All values are optional — the app runs without any.

# Enables real Gemini embeddings + answer synthesis. Without it, the app uses a
# built-in TF-IDF retriever + extractive answers (fully functional, no API calls).
GEMINI_API_KEY=

# Security — CHANGE THIS in production.
SECRET_KEY=dev-secret-change-me-in-production

# Database — SQLite by default. For Postgres:
# DATABASE_URL=postgresql+psycopg://user:pass@localhost:5432/findocai
DATABASE_URL=

# Freemium limits
FREE_DOC_LIMIT=10
FREE_QUERY_LIMIT=100

# Token lifetimes
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
